{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agugagatada-destination",
  "title": "Agugagatada Destination",
  "description": "Schema for a single day-trip destination file in data/*.json",
  "type": "object",
  "required": [
    "id", "title", "tagline", "destination", "origin",
    "drive_time_from_origin_minutes", "duration_days", "generated_at", "updated_at",
    "stats", "intro", "route_polyline", "days",
    "hotels", "hikes", "practical_notes", "detour_stops"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Kebab-case slug, e.g. 'bamberg-daytrip'. Lowercase, hyphens, digits; Unicode letters allowed for place names (e.g. 'frankenhöhe-ridge').",
      "pattern": "^\\S+$"
    },
    "title": {
      "type": "string",
      "description": "Long editorial title shown in browser tab and page heading"
    },
    "tagline": {
      "type": "string",
      "description": "One-sentence hook for the destination"
    },
    "destination": {
      "type": "object",
      "required": ["name", "region", "lat", "lon"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "region": { "type": "string" },
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "origin": {
      "type": "object",
      "required": ["name", "lat", "lon"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "drive_time_from_origin_minutes": {
      "type": "integer",
      "minimum": 1
    },
    "duration_days": {
      "type": "integer",
      "minimum": 1
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 date when the content was first generated — never changes after creation",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 date of the last content revision — update this whenever any field changes",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "stats": {
      "type": "object",
      "required": [
        "total_stops", "baby_friendly_score",
        "history_depth_score", "touristic_score", "drive_total_km"
      ],
      "additionalProperties": false,
      "properties": {
        "total_stops": { "type": "integer", "minimum": 1 },
        "baby_friendly_score": { "type": "integer", "minimum": 1, "maximum": 5 },
        "history_depth_score": { "type": "integer", "minimum": 1, "maximum": 5 },
        "touristic_score": { "type": "integer", "minimum": 1, "maximum": 5 },
        "drive_total_km": { "type": "number", "minimum": 1 }
      }
    },
    "intro": {
      "type": "string",
      "description": "Editorial overview, 1–3 paragraphs"
    },
    "route_polyline": {
      "type": "array",
      "description": "Array of [lat, lon] waypoints from Munich to destination",
      "minItems": 2,
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": { "type": "number" }
      }
    },
    "days": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["day_number", "title", "theme", "summary", "stops"],
        "additionalProperties": false,
        "properties": {
          "day_number": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "theme": { "type": "string" },
          "summary": { "type": "string" },
          "stops": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/definitions/stop" }
          }
        }
      }
    },
    "hotels": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/hotel" }
    },
    "hikes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/hike" }
    },
    "practical_notes": {
      "type": "array",
      "description": "Flat array of plain-text tips",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "detour_stops": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/detour" }
    }
  },
  "definitions": {
    "stop": {
      "type": "object",
      "required": [
        "id", "sequence", "name", "subtitle", "lat", "lon",
        "category", "visit_duration_minutes", "drive_time_from_prev_minutes",
        "baby_friendly_score", "highlight", "about", "hidden_gems",
        "baby_logistics", "tier", "skip_if_rushed"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^\\S+$" },
        "sequence": { "type": "integer", "minimum": 1 },
        "name": { "type": "string" },
        "subtitle": { "type": "string" },
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon": { "type": "number", "minimum": -180, "maximum": 180 },
        "category": {
          "type": "string",
          "enum": ["castle", "church", "history", "monument", "museum", "nature", "town_center"]
        },
        "visit_duration_minutes": { "type": "integer", "minimum": 1 },
        "drive_time_from_prev_minutes": { "type": "integer", "minimum": 0 },
        "baby_friendly_score": { "type": "integer", "minimum": 1, "maximum": 5 },
        "highlight": { "type": "string" },
        "about": { "type": "string" },
        "hidden_gems": { "type": "string" },
        "baby_logistics": { "type": "string" },
        "tier": { "type": "integer", "enum": [1, 2, 3] },
        "skip_if_rushed": { "type": "boolean" }
      }
    },
    "hotel": {
      "type": "object",
      "required": [
        "id", "name", "area", "type", "local_character_score",
        "price_range", "has_crib", "has_parking", "description", "why_recommended"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^\\S+$" },
        "name": { "type": "string" },
        "area": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "3-Star Hotel", "Boutique Hotel", "Gasthof", "Guesthouse",
            "Historic Gasthof", "Historic Hotel", "Luxury Hotel",
            "Modern Hotel", "Pension"
          ]
        },
        "local_character_score": { "type": "integer", "minimum": 1, "maximum": 5 },
        "price_range": { "type": "string" },
        "has_crib": { "type": "boolean" },
        "has_parking": { "type": "boolean" },
        "description": { "type": "string" },
        "why_recommended": { "type": "string" }
      }
    },
    "hike": {
      "type": "object",
      "required": [
        "id", "name", "area", "distance_km", "elevation_gain_m",
        "estimated_time_minutes", "difficulty", "pushchair_friendly",
        "baby_carrier_feasible", "surface", "description", "practical_tip"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^\\S+$" },
        "name": { "type": "string" },
        "area": { "type": "string" },
        "distance_km": { "type": "number", "minimum": 0 },
        "elevation_gain_m": { "type": "integer", "minimum": 0 },
        "estimated_time_minutes": { "type": "integer", "minimum": 1 },
        "difficulty": { "type": "string", "enum": ["easy", "moderate", "hard"] },
        "pushchair_friendly": { "type": "boolean" },
        "baby_carrier_feasible": { "type": "boolean" },
        "surface": { "type": "string" },
        "description": { "type": "string" },
        "practical_tip": { "type": "string" }
      }
    },
    "detour": {
      "type": "object",
      "required": [
        "id", "name", "tagline", "position", "lat", "lon",
        "detour_from_route_minutes", "visit_duration_minutes", "best_time",
        "category", "baby_friendly_score", "highlight", "description", "practical"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^\\S+$" },
        "name": { "type": "string" },
        "tagline": { "type": "string" },
        "position": { "type": "string", "enum": ["en_route", "near_destination"] },
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon": { "type": "number", "minimum": -180, "maximum": 180 },
        "detour_from_route_minutes": { "type": "integer", "minimum": 0 },
        "visit_duration_minutes": { "type": "integer", "minimum": 1 },
        "best_time": { "type": "string", "enum": ["any", "morning", "afternoon", "evening"] },
        "category": {
          "type": "string",
          "enum": ["castle", "church", "history", "monument", "museum", "nature", "town_center"]
        },
        "baby_friendly_score": { "type": "integer", "minimum": 1, "maximum": 5 },
        "highlight": { "type": "string" },
        "description": { "type": "string" },
        "practical": { "type": "string" }
      }
    }
  }
}
